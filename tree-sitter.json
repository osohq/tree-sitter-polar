    "description": "A declarative logic programming language specialized for authorization logic.",
    "authors": [
      {
        "name": "Aru Sahni",
        "email": "aru@osohq.com"
      }
    ],
    "links": {
      "repository": "https://github.com/arusahni/tree-sitter-polar"
    }
  },
  "bindings": {
